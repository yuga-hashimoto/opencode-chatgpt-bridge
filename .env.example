# HTTP server exposed to ChatGPT through a secure tunnel.
OPENCODE_BRIDGE_HOST=127.0.0.1
OPENCODE_BRIDGE_PORT=8787

# Strongly recommended when exposing through ngrok/cloudflared.
# ChatGPT/clients must send: Authorization: Bearer <token>
OPENCODE_BRIDGE_TOKEN=

# Colon-separated list of directories containing repos the bridge may access.
OPENCODE_BRIDGE_ALLOWED_ROOTS=/Users/me/dev:/Volumes/MOVESPEED/Documents/GitHub

# Optional: if set, do not spawn opencode; use this server for every repo.
OPENCODE_BASE_URL=
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=

# When spawning opencode per repo.
OPENCODE_BIN=opencode
OPENCODE_BRIDGE_OPENCODE_PORT_START=4096

# Optional cloudflare tunnel automation.
OPENCODE_BRIDGE_TUNNEL=none
CLOUDFLARED_BIN=cloudflared
