# HTTP server exposed to ChatGPT through a secure tunnel.
OPENCODE_BRIDGE_HOST=127.0.0.1
OPENCODE_BRIDGE_PORT=8787
# If true, falls back to 8788/8789/etc when the preferred port is already in use.
OPENCODE_BRIDGE_AUTO_PORT=true
# Public hosts accepted by the MCP SDK Host validation. Add your Tailscale Funnel hostname here.
OPENCODE_BRIDGE_ALLOWED_HOSTS=127.0.0.1,localhost,hashimotoyugamac-mini.tailf9f6e3.ts.net

# Strongly recommended when exposing through ngrok/cloudflared.
# ChatGPT/clients can send Authorization: Bearer <token>.
# The bridge also prints a /mcp?token=<token> fallback URL for connector UIs without custom headers.
OPENCODE_BRIDGE_TOKEN=

# Colon-separated list of directories containing repos the bridge may access.
OPENCODE_BRIDGE_ALLOWED_ROOTS=/Users/me/dev:/Volumes/MOVESPEED/Documents/GitHub

# Optional: if set, do not spawn opencode; use this server for every repo.
OPENCODE_BASE_URL=
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=

# When spawning opencode per repo.
OPENCODE_BIN=opencode
OPENCODE_BRIDGE_OPENCODE_PORT_START=4096

# Optional cloudflare tunnel automation.
# `opencode-chatgpt-bridge init` defaults this to cloudflare for a ready-to-connect first run.
OPENCODE_BRIDGE_TUNNEL=tailscale
TAILSCALE_BIN=/Applications/Tailscale.app/Contents/MacOS/Tailscale
CLOUDFLARED_BIN=cloudflared
